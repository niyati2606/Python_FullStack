-- adding last_modified column into books table
ALTER TABLE books
ADD COLUMN last_modified DATETIME DEFAULT NOW();

SELECT * FROM books;

-- creating trigger for last_modified timestamp of the books
CREATE OR REPLACE TRIGGER update_last_modified
BEFORE UPDATE ON books
FOR EACH ROW
SET NEW.last_modified = NOW();

-- updating data in books table for test
UPDATE books SET title = 'New Book' WHERE id = 1;
SELECT id, title, last_modified FROM books WHERE id = 1;

