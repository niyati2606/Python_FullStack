-- Create the view
CREATE VIEW view_books_summary AS
SELECT
    b.book_id,
    b.title,
    CONCAT(a.first_name, ' ', a.last_name) AS author_name,
    b.price
FROM   books b
LEFT JOIN authors a ON b.author_id = a.author_id;

-- display the view
SELECT * FROM book_details_view;

