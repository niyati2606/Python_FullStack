-- View : Members who joined before 2020

CREATE VIEW view_early_members AS
SELECT
    member_id,
    member_name,
    date_of_membership,
    email
FROM   members
WHERE  date_of_membership < '2020-01-01';
 
 -- display the view
 SELECT * FROM view_early_members;