-- check employee department using if-else
DELIMITER //

CREATE PROCEDURE check_employee_department(IN p_emp_id INT)
BEGIN
    DECLARE dept_name VARCHAR(50);

    -- Get department name using JOIN
    SELECT d.dept_name INTO dept_name
    FROM employees e
    JOIN departments d ON e.dept_id = d.dept_id
    WHERE e.emp_id = p_emp_id;

    -- IF-THEN logic
    IF dept_name = 'HR' THEN
        SELECT 'Employee works in HR department' AS Message;
    ELSEIF dept_name = 'IT' THEN
        SELECT 'Employee works in IT department' AS Message;
    ELSE
        SELECT CONCAT('Employee works in ', dept_name, ' department') AS Message;
    END IF;

END //

DELIMITER ;

CALL check_employee_department(1);

