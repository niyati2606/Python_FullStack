-- IF-THEN-ELSE to check if a book's price
DELIMITER $$

CREATE PROCEDURE CheckBookPrice(
    IN p_title  VARCHAR(100),
    IN p_price  DECIMAL(10,2)
)
BEGIN
    IF p_price > 100 THEN
        SELECT  p_title  AS Book_Title,
                p_price  AS Price,
                'EXPENSIVE – Price is above 100.' AS Status;
    ELSE
        SELECT  p_title  AS Book_Title,
                p_price  AS Price,
                'AFFORDABLE – Price is 100 or below.' AS Status;
    END IF;
END$$

DELIMITER ;

-- call it
CheckBookPrice("The Rozabal Line",85)
CheckBookPrice("The Rozabal Line",105)

