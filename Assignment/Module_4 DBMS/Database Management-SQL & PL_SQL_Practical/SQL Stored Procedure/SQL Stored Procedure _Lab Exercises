-- Retrieve all books by particular author
DELIMITER $$
 
CREATE PROCEDURE GetBooksByAuthor(
    IN p_author_name VARCHAR(100)       -- IN parameter: full author name
)
BEGIN
    SELECT
        b.book_id,
        b.title,
        CONCAT(a.first_name, ' ', a.last_name) AS author_name,
        b.publisher,
        b.year_of_publication,
        b.price,
        b.genre
    FROM   books b
    INNER JOIN authors a ON b.author_id = a.author_id
    WHERE  CONCAT(a.first_name, ' ', a.last_name) = p_author_name
    ORDER BY b.year_of_publication ASC;
END$$
 
DELIMITER ;

-- Call it
CALL GetBooksByAuthor('Amish Tripathi');

