-- Procedure: Get Price by book_id 

DELIMITER $$
 
CREATE PROCEDURE GetBookPrice(
    IN  p_book_id INT,                  -- IN  parameter: book_id to look up
    OUT p_price   DECIMAL(6, 2)         -- OUT parameter: price returned to caller
)
BEGIN
    SELECT price
    INTO   p_price
    FROM   books
    WHERE  book_id = p_book_id;
END$$
 
DELIMITER ;

--call it
CALL GetBookPrice(3, @price);