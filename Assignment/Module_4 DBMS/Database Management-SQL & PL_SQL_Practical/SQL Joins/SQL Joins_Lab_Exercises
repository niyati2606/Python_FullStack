-- inner join
SELECT
    b.book_id,
    b.title,
    CONCAT(a.first_name, ' ', a.last_name) AS author_name,
    a.country
FROM books b
INNER JOIN authors a ON b.author_id = a.author_id
ORDER BY b.book_id;

-- full outer join
SELECT b.book_id, b.title, a.author_id,
       CONCAT(a.first_name, ' ', a.last_name) AS author_name
FROM books b LEFT JOIN authors a  ON b.author_id = a.author_id
UNION
SELECT b.book_id, b.title, a.author_id,
       CONCAT(a.first_name, ' ', a.last_name) AS author_name
FROM books b RIGHT JOIN authors a ON b.author_id = a.author_id
ORDER BY book_id, author_id;
