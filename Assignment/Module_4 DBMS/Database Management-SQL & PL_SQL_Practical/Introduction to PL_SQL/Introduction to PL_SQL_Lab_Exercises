-- get total books
DELIMITER $$

CREATE PROCEDURE get_total_books()
BEGIN
    DECLARE total INT;

    SELECT COUNT(*) INTO total FROM books;

    SELECT CONCAT('Total number of books : ', total) AS message;
END $$

DELIMITER ;

CALL get_total_books();