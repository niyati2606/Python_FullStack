-- print total numbers of employee
DELIMITER //

CREATE PROCEDURE total_employees_proc()
BEGIN
    DECLARE v_total_employees INT;

    SELECT COUNT(*) INTO v_total_employees
    FROM employees;

    SELECT CONCAT('Total Employees: ', v_total_employees) AS Result;
END //

DELIMITER ;

CALL total_employees_proc();

