-- Cursor: Fetch All Members

DELIMITER $$
CREATE PROCEDURE FetchAllMembers()
BEGIN
    DECLARE v_member_id   INT;
    DECLARE v_member_name VARCHAR(100);
    DECLARE v_date        DATE;
    DECLARE v_email       VARCHAR(100);
    DECLARE v_done        INT DEFAULT 0;

    DECLARE cur_members CURSOR FOR
        SELECT member_id, member_name, date_of_membership, email
        FROM   members ORDER BY member_id;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET v_done = 1;

    OPEN cur_members;
    read_loop: LOOP
        FETCH cur_members INTO v_member_id, v_member_name, v_date, v_email;
        IF v_done = 1 THEN LEAVE read_loop; END IF;
        -- process each row
    END LOOP;
    CLOSE cur_members;
END$$
DELIMITER ;

CALL FetchAllMembers();

