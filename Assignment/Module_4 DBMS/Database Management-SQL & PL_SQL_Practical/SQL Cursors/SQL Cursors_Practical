-- cursor to retrive all courses
DELIMITER $$

CREATE PROCEDURE show_courses()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE c_id INT;
    DECLARE c_name VARCHAR(100);

    DECLARE course_cursor CURSOR FOR 
        SELECT course_id, course_name FROM courses;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    OPEN course_cursor;

    course_loop: LOOP
        FETCH course_cursor INTO c_id, c_name;
        IF done THEN
            LEAVE course_loop;
        END IF;

        SELECT c_id AS CourseID, c_name AS CourseName;
    END LOOP;

    CLOSE course_cursor;
END$$

DELIMITER ;

CALL show_courses();