-- SAVEPOINT + ROLLBACK TO SAVEPOINT on members
START TRANSACTION;

SAVEPOINT before_update;

UPDATE members_backup SET email = "niya@gmail.com" WHERE member_id = 1;

SELECT * FROM members_backup ORDER BY member_id;

ROLLBACK TO SAVEPOINT before_update;
SELECT * FROM members_backup ORDER BY member_id;
