--  INSERT → SAVEPOINT → UPDATE → ROLLBACK TO SAVEPOINT
SELECT * FROM members ORDER BY member_id;

START TRANSACTION;
INSERT INTO members (member_id, member_name, date_of_membership, email)
VALUES (11, 'Kiran Patel', '2024-04-01', 'kiran.patel@email.com');
 
SELECT * FROM members WHERE member_id = 11;

SAVEPOINT after_insert;
 
UPDATE members SET member_name  = 'Kiran Kumar' WHERE member_id = 11;
UPDATE members SET email = 'kiran.kumar@email.com' WHERE member_id = 11;
UPDATE members SET date_of_membership = '2026-01-01'  WHERE member_id = 1;
 
SELECT * FROM members WHERE member_id IN (1, 11);

ROLLBACK TO SAVEPOINT after_insert;

SELECT * FROM members WHERE member_id IN (1, 11);

