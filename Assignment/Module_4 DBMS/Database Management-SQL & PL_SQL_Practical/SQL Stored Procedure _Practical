-- Retrieve employees by department
DELIMITER $$

CREATE PROCEDURE GetEmployeesByDepartment(IN p_dept_id INT)
BEGIN
    SELECT
        emp_id,
        emp_name,
        salary,
        dept_id
    FROM employees
    WHERE dept_id = p_dept_id;
END $$

DELIMITER ;

-- Call it
-- CALL GetEmployeesByDepartment(1);  -- returns mobile employees
CALL GetEmployeesByDepartment(3);  -- returns back end employees

--Retrieve course details by course_id
DELIMITER $$

CREATE PROCEDURE GetCourseById(IN c_id INT)
BEGIN
    SELECT * 
    FROM courses
    WHERE course_id = c_id;
END $$

DELIMITER ;

--call it
CALL GetCourseById(201);
